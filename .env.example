COMPOSE_PROJECT_NAME=vlf_chrome_proxy

APP_ENV=production
LOG_LEVEL=info

HTTP_LISTEN_ADDR=:8080
HTTPS_PROXY_LISTEN_ADDR=:443
HTTPS_PROXY_TLS_CERT_PATH=/runtime/tls/proxy.crt
HTTPS_PROXY_TLS_KEY_PATH=/runtime/tls/proxy.key
BACKEND_PORT=18080
HTTPS_PROXY_PORT=443

TOKEN_PEPPER=replace-with-long-random-secret
PROXY_PASSWORD_PEPPER=replace-with-second-long-random-secret

SESSION_TTL_HOURS=24
PROXY_CREDENTIAL_TTL_HOURS=24
DEFAULT_BYPASS_LIST="<local>,127.0.0.1"

ACCESS_LINK_BASE_URL=https://access.example.com

CORS_ALLOW_CHROME_EXTENSION_ORIGINS=true
CORS_ALLOWED_ORIGINS=
ALLOWED_CHROME_EXTENSION_IDS=

PROXY_ALLOW_PRIVATE_DESTINATIONS=false

NODE_DEFAULT_ID=node-1
NODE_DEFAULT_NAME="Finland #1"
NODE_DEFAULT_COUNTRY=FI
NODE_DEFAULT_CITY=Helsinki
PROXY_PUBLIC_HOST=proxy.example.com
PROXY_PUBLIC_PORT=443

AUTO_CREATE_BOOTSTRAP_LINK=false
BOOTSTRAP_ACCESS_LINK_LABEL=bootstrap
BOOTSTRAP_ACCESS_LINK_EXPIRES_IN=720h
